{
  "name": "@babajidemm/african-countries-api",
  "version": "2.0.2",
  "description": "A Node.js library that provides APIs to get useful data about African countries including their cities (with more than 500 inhabitants).",
  "main": "index.js",
  "files": [
    "api/**/*",
    "index.js",
    "version.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "nyc --reporter=text-lcov node --test test/*.js",
    "coverage": "nyc --reporter=text-lcov report"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "author": "Babajide Mayowa Moibi <babajidemm@gmail.com> (info@moibi.de)",
  "license": "MIT",
  "keywords": [
    "african",
    "countries",
    "api",
    "african-countries-api",
    "african-countries",
    "AfricanCountriesAPI",
    "json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babajidemm/african-countries-api.git"
  },
  "bugs": {
    "url": "https://github.com/babajidemm/african-countries-api/issues"
  },
  "homepage": "https://github.com/babajidemm/african-countries-api#readme",
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "http-response-object": "^3.0.2"
  },
  "devDependencies": {
    "nyc": "^18.0.0",
    "should": "^13.2.3"
  }
}
